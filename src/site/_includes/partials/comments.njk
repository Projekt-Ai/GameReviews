{# Static comments placeholder; backend comments have been removed. #}
<section class="review-comments" data-comment-thread="{{ threadId }}">
  <div class="comments-header">
    <span class="comments-header-pip"></span>
    <h2 class="comments-title">Discussion</h2>
    <span class="comments-count">Unavailable</span>
  </div>

  <div class="comment-form-wrap">
    <div class="comment-avatar"></div>
    <div class="comment-form">
      <p class="comment-body">Comments are offline while the site runs as a fully static build.</p>
      <p class="comment-form-status">Frontend layout is preserved, but there is no backend comment service.</p>
    </div>
  </div>

  <div class="comments-list">
    <div class="comment">
      <div class="comment-inner">
        <div class="comment-avatar"></div>
        <div>
          <div class="comment-head">
            <span class="comment-author">Comments disabled</span>
          </div>
          <p class="comment-body">This page no longer loads or submits comments.</p>
        </div>
      </div>
    </div>
  </div>
</section>
