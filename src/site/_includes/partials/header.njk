{# Shared desktop + mobile navigation header. #}
{% set currentUrl = page.url or "/" %}
<header class="site-header">
  <div class="header-main">
    <a class="logo" href="/">KAT</a>

    <div class="header-center">
      <a class="brand" href="/">A Kat's Kronicles</a>

      {# Desktop nav links use the `isActiveNav` filter for highlighting. #}
      <nav class="nav" aria-label="Main navigation">
        <div class="nav-inner">
          {# Each link conditionally gets `is-active` when its route matches the current page. #}
          <a href="/reviews" class="{% if currentUrl | isActiveNav('/reviews') %}is-active{% endif %}">Reviews</a>
          <a href="/bossfeatures" class="{% if currentUrl | isActiveNav('/bossfeatures') %}is-active{% endif %}">Boss Features</a>
          <a href="/search" class="{% if currentUrl | isActiveNav('/search') %}is-active{% endif %}">Search</a>
          <a href="/about" class="{% if currentUrl | isActiveNav('/about') %}is-active{% endif %}">About</a>
          <a href="/news" class="{% if currentUrl | isActiveNav('/news') %}is-active{% endif %}">News</a>
          <a href="/music-appreciation" class="{% if currentUrl | isActiveNav('/music-appreciation') %}is-active{% endif %}">Music Appreciation</a>
          <a href="/imexcited" class="{% if currentUrl | isActiveNav('/imexcited') %}is-active{% endif %}">I'm Excited</a>
        </div>
      </nav>
    </div>

    <div class="header-actions">
      {# Small search form routes to the search page via query string. #}
      <div class="header-search">
        <form role="search" action="/search/" method="get">
          <div class="search-field">
            <span class="search-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
                <path d="M20 20L16.65 16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
              </svg>
            </span>
            <input type="text" name="q" placeholder="Search" aria-label="Search Game Reviews" />
          </div>
        </form>
      </div>

      <button class="mobile-menu-toggle" aria-label="Open menu" aria-expanded="false">
        <svg class="icon-hamburger" viewBox="0 0 24 24" fill="none" width="22" height="22">
          <path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <svg class="icon-close" viewBox="0 0 24 24" fill="none" width="22" height="22">
          <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </div>
</header>

{# Mobile menu overlay/panel are toggled by the inline script below. #}
<div class="mobile-overlay" aria-hidden="true"></div>
<nav class="mobile-panel" aria-label="Mobile navigation" aria-hidden="true">
  <div class="mobile-panel-links">
    {# Mobile links use the same active-class pattern as the desktop nav. #}
    <a href="/" class="{% if currentUrl | isActiveNav('/') %}is-active{% endif %}">Home</a>
    <a href="/reviews" class="{% if currentUrl | isActiveNav('/reviews') %}is-active{% endif %}">Reviews</a>
    <a href="/bossfeatures" class="{% if currentUrl | isActiveNav('/bossfeatures') %}is-active{% endif %}">Boss Features</a>
    <a href="/search" class="{% if currentUrl | isActiveNav('/search') %}is-active{% endif %}">Search</a>
    <a href="/about" class="{% if currentUrl | isActiveNav('/about') %}is-active{% endif %}">About</a>
    <a href="/news" class="{% if currentUrl | isActiveNav('/news') %}is-active{% endif %}">News</a>
    <a href="/music-appreciation" class="{% if currentUrl | isActiveNav('/music-appreciation') %}is-active{% endif %}">Music Appreciation</a>
    <a href="/imexcited" class="{% if currentUrl | isActiveNav('/imexcited') %}is-active{% endif %}">I'm Excited</a>
  </div>
</nav>

<script>
(() => {
  // Simple mobile menu controller (toggle, backdrop click, Escape key).
  const toggle = document.querySelector('.mobile-menu-toggle');
  const overlay = document.querySelector('.mobile-overlay');
  const panel = document.querySelector('.mobile-panel');
  // Exit on pages where the mobile nav markup is unavailable.
  if (!toggle || !overlay || !panel) return;

  function openMenu() {
    panel.classList.add('is-open');
    overlay.classList.add('is-open');
    toggle.setAttribute('aria-expanded', 'true');
    panel.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    panel.classList.remove('is-open');
    overlay.classList.remove('is-open');
    toggle.setAttribute('aria-expanded', 'false');
    panel.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  toggle.addEventListener('click', () => {
    const isOpen = panel.classList.contains('is-open');
    // Ternary keeps the click handler compact while toggling open/close behavior.
    isOpen ? closeMenu() : openMenu();
  });

  overlay.addEventListener('click', closeMenu);
  document.addEventListener('keydown', (e) => {
    // Allow keyboard users to dismiss the mobile menu with Escape.
    if (e.key === 'Escape') closeMenu();
  });
})();
</script>
