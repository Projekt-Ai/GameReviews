{# Derive common metadata values with page-level overrides. #}
{% set pageTitle = headTitle or title or site.title %}
{% set pageDescription = description or site.description %}
{% set pageImage = imageUrl or "/assets/blog-placeholder-1.jpg" %}
{# Base metadata, icons, and shared stylesheet. #}
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="stylesheet" href="/styles/global.css" />
<link rel="sitemap" href="/sitemap.xml" />
<link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="{{ build.siteUrl }}/rss.xml" />
<meta name="generator" content="Eleventy" />
<meta name="x-build-commit" content="{{ build.commit }}" />
<meta name="x-deploy-context" content="{{ build.context }}" />

{# Font preloads + Google font families used across the site. #}
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Merriweather:wght@400;700&family=Orbitron:wght@400;700&family=Cinzel:wght@400;600;700&display=swap"
/>
{# Only load the extra literary font on pages that opt into it. #}
{% if variantFonts %}
{# Optional literary font variant used by select page layouts/themes. #}
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IM+Fell+Double+Pica:ital@0;1&display=swap" />
{% endif %}

{# SEO / social metadata. #}
<link rel="canonical" href="{{ build.siteUrl }}{{ page.url }}" />
<title>{{ pageTitle }}</title>
<meta name="title" content="{{ pageTitle }}" />
<meta name="description" content="{{ pageDescription }}" />
<meta property="og:type" content="website" />
<meta property="og:url" content="{{ build.siteUrl }}{{ page.url }}" />
<meta property="og:title" content="{{ pageTitle }}" />
<meta property="og:description" content="{{ pageDescription }}" />
<meta property="og:image" content="{{ build.siteUrl }}{{ pageImage }}" />
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content="{{ build.siteUrl }}{{ page.url }}" />
<meta property="twitter:title" content="{{ pageTitle }}" />
<meta property="twitter:description" content="{{ pageDescription }}" />
<meta property="twitter:image" content="{{ build.siteUrl }}{{ pageImage }}" />
{# Page-specific assets declared in front matter / 11ty data files. #}
{# Attach page-specific stylesheets declared by front matter / data files. #}
{% for href in stylesheets or [] %}
<link rel="stylesheet" href="{{ href }}" />
{% endfor %}
{# Attach page-specific scripts (deferred by default unless explicitly disabled). #}
{% for script in scripts or [] %}
{# `type` is optional and `defer` is included unless the script explicitly disables it. #}
<script src="{{ script.src }}" {% if script.type %}type="{{ script.type }}"{% endif %} {% if script.defer != false %}defer{% endif %}></script>
{% endfor %}
