<html lang="en">
  <head>
    {# Shared head metadata + boss-feature specific stylesheet. #}
    {% include "partials/base-head.njk" %}
    <link rel="stylesheet" href="/styles/layouts/boss-feature.css" />
    {% if comments and threadId %}<link rel="stylesheet" href="/styles/components/comments.css" />{% endif %}
  </head>
  <body class="boss-feature">
    {# Global site navigation. #}
    {% include "partials/header.njk" %}
    <main>
      {# Cinematic boss-feature hero section. #}
      <section class="bf-hero">
        {# Boss features can render without a hero image, so guard this block. #}
        {% if heroImageHtml %}
        <div class="bf-hero-img">
          {{ heroImageHtml | safe }}
        </div>
        {% endif %}
        <div class="bf-hero-bg"></div>
        <div class="bf-hero-lines" aria-hidden="true"></div>
        <div class="bf-hero-vignette" aria-hidden="true"></div>

        <div class="bf-hero-content">
          <div class="bf-boss-tag">Boss Feature</div>
          <p class="bf-hero-game">{{ game }}</p>
          <h1 class="bf-hero-title">{{ title }}</h1>
          {# Subtitle blurb is optional front matter. #}
          {% if blurb %}<p class="bf-hero-subtitle">{{ blurb }}</p>{% endif %}
          <div class="bf-hero-meta">
            <span class="bf-hero-meta-item">By KAT</span>
            {# Hours-in and chapter metadata are optional and hidden when missing. #}
            {% if hoursIn %}
              <span class="bf-hero-meta-sep" aria-hidden="true"></span>
              <span class="bf-hero-meta-item">{{ hoursIn }}</span>
            {% endif %}
            {% if chapter %}
              <span class="bf-hero-meta-sep" aria-hidden="true"></span>
              <span class="bf-hero-meta-item">{{ chapter }}</span>
            {% endif %}
            <span class="bf-hero-meta-sep" aria-hidden="true"></span>
            <span class="bf-hero-meta-item"><time datetime="{{ pubDate.toISOString() }}">{{ pubDate | formatDate }}</time></span>
          </div>
        </div>
      </section>

      {# Article body wrapper with metadata card + content + verdict block. #}
      <div class="bf-article-wrap">
        <div class="bf-byline">
          <span><strong>KAT</strong></span>
          <span class="bf-byline-sep">&middot;</span>
          <span>{{ game }}</span>
          <span class="bf-byline-sep">&middot;</span>
          <span>Boss Feature</span>
        </div>

        <div class="bf-boss-card">
          <div class="bf-boss-card-field"><span class="bf-boss-card-label">Boss</span><span class="bf-boss-card-value">{{ title }}</span></div>
          <div class="bf-boss-card-field"><span class="bf-boss-card-label">Game</span><span class="bf-boss-card-value">{{ game }}</span></div>
          <div class="bf-boss-card-field"><span class="bf-boss-card-label">Type</span><span class="bf-boss-card-value">{{ bossType }}</span></div>
          {# Show attempt count even when the value is 0, so check against `none`. #}
          {% if attempts is not none %}<div class="bf-boss-card-field"><span class="bf-boss-card-label">Attempts</span><span class="bf-boss-card-value">{{ attempts }}</span></div>{% endif %}
          {# Verdict row and its tone class are optional. #}
          {% if verdict %}
          <div class="bf-boss-card-field">
            <span class="bf-boss-card-label">Verdict</span>
            {# Add the tone modifier class only when one was computed from front matter. #}
            <span class="bf-boss-card-value{% if verdictToneClass %} {{ verdictToneClass }}{% endif %}">{{ verdict }}</span>
          </div>
          {% endif %}
          {# Spoiler label only appears when supplied in front matter. #}
          {% if spoilerLevel %}<div class="bf-boss-card-field"><span class="bf-boss-card-label">Spoiler Level</span><span class="bf-boss-card-value">{{ spoilerLevel }}</span></div>{% endif %}
        </div>

        {{ content | safe }}

        {# Final take box is optional and rendered after the body content. #}
        {% if verdictText %}
        <div class="bf-verdict">
          <p class="bf-verdict-eyebrow">Final Take</p>
          <p class="bf-verdict-text">{{ verdictText }}</p>
          {# Tag badges only render when there are tags to display. #}
          {% if tags and tags.length > 0 %}
          <div class="bf-verdict-tags">
            {# Map each tag label to a CSS badge class via `tagClasses`. #}
            {% for tag in tags %}
            {# Use a mapped tag class when available, otherwise fall back to a default style. #}
            <span class="bf-verdict-tag {{ tagClasses[(tag | lower)] or 'bf-tag-spectacle' }}">{{ tag }}</span>
            {% endfor %}
          </div>
          {% endif %}
        </div>
        {% endif %}
      </div>
      {# Optional seeded comments UI, enabled per post. #}
      {# Comments module requires both a feature flag and a thread id key. #}
      {% if comments and threadId %}
        {% include "partials/comments.njk" %}
      {% endif %}
    </main>
    {% include "partials/footer.njk" %}
  </body>
</html>
