{# Reviews archive page header (title, subtitle, total count). #}
<section class="page-head">
  <div>
    <p class="page-eyebrow">{{ site.title }} / Archive</p>
    <h1 class="page-title">{{ reviewsPage.header.title }}</h1>
    <p class="page-subtitle">{{ reviewsPage.header.subtitle }}</p>
  </div>
  <div class="page-head-right">
    <span class="review-count">{{ reviewsPage.header.countText }}</span>
  </div>
</section>

{# Client-side filter/sort controls. Buttons are "display only" until the injected script binds behavior. #}
<section class="filters-bar" aria-label="Review filters (display only)">
  <span class="filter-label">Filter</span>
  <button type="button" class="filter-btn active" data-filter-reset="true">All</button>

  {# Genre filter chips come from the precomputed top-genre list. #}
  {% for genre in reviewsPage.filters.genres %}
  <button type="button" class="filter-btn" data-filter-type="genre" data-filter-value="{{ genre.value }}">
    {{ genre.name }}
  </button>
  {% endfor %}

  {# Only show a separator if the next filter group actually exists. #}
  {% if reviewsPage.filters.platforms.length > 0 %}
  <span class="filter-sep" aria-hidden="true"></span>
  {% endif %}
  {# Platform filters are normalized buckets (PC / PlayStation / Switch / Xbox). #}
  {% for platform in reviewsPage.filters.platforms %}
  <button type="button" class="filter-btn" data-filter-type="platform" data-filter-value="{{ platform.value }}">
    {{ platform.name }}
  </button>
  {% endfor %}

  {# Add another separator only when year filters are present. #}
  {% if reviewsPage.filters.years.length > 0 %}
  <span class="filter-sep" aria-hidden="true"></span>
  {% endif %}
  {# Year filters are limited to recent archive years for a compact toolbar. #}
  {% for year in reviewsPage.filters.years %}
  <button type="button" class="filter-btn" data-filter-type="year" data-filter-value="{{ year.value }}">
    {{ year.year }}
  </button>
  {% endfor %}

  <div class="sort-group">
    <label for="reviews-sort" class="sort-label">Sort</label>
    <select id="reviews-sort" class="sort-select" data-sort-select>
      <option value="newest">Newest</option>
      <option value="oldest">Oldest</option>
    </select>
  </div>
</section>

{# Two-column page shell: archive content + stats/sidebar. #}
<div class="reviews-layout">
  <div class="reviews-column">
    {# Featured area: one hero card plus optional supporting tiles. #}
    {# Featured section is optional (e.g., if there are no real review posts yet). #}
    {% if reviewsPage.featured.hero %}
    <section class="featured" aria-label="Featured reviews" data-featured-wrap>
      <div class="featured-label">Featured</div>

      {% set hero = reviewsPage.featured.hero %}
      <a
        href="{{ hero.href }}"
        class="featured-card featured-card-hero"
        data-post-card
        data-featured-card
        {% if hero.isMock %}data-mock="true"{% endif %}
        data-date="{{ hero.dateIso }}"
        data-year="{{ hero.year }}"
        data-title="{{ hero.titleLower }}"
        data-genres="{{ hero.genresTokens }}"
        data-platforms="{{ hero.platformsTokens }}"
      >
        <div class="featured-media">{{ hero.imageHtml | safe }}</div>
        <div class="featured-overlay" aria-hidden="true"></div>
        <div class="featured-content">
          <p class="featured-kicker">{{ hero.featuredKicker }}</p>
          <h2 class="featured-title">{{ hero.data.title }}</h2>
          <p class="featured-summary">{{ hero.featuredSummary }}</p>
          <div class="featured-meta">
            {% for platform in hero.playedPlatforms %}
            <span class="featured-pill">{{ platform }}</span>
            {% endfor %}
            <span class="featured-date">
              <time datetime="{{ hero.dateIso }}">{{ hero.formattedDate }}</time>
            </span>
          </div>
        </div>
      </a>

      {# Supporting featured tiles render only when there are enough featured posts. #}
      {% if reviewsPage.featured.tiles.length > 0 %}
      <div class="featured-subgrid" data-featured-subgrid>
        {# Loop through the secondary featured cards. #}
        {% for post in reviewsPage.featured.tiles %}
        <a
          href="{{ post.href }}"
          class="featured-card featured-card-tile"
          data-post-card
          data-featured-card
          {% if post.isMock %}data-mock="true"{% endif %}
          data-date="{{ post.dateIso }}"
          data-year="{{ post.year }}"
          data-title="{{ post.titleLower }}"
          data-genres="{{ post.genresTokens }}"
          data-platforms="{{ post.platformsTokens }}"
        >
          <div class="featured-media">{{ post.imageHtml | safe }}</div>
          <div class="featured-overlay" aria-hidden="true"></div>
          <div class="featured-content">
            <p class="featured-kicker">{{ post.featuredKicker }}</p>
            <h3 class="featured-title">{{ post.data.title }}</h3>
            <div class="featured-meta">
              {# Preferred platform is optional if platform metadata is missing. #}
              {% if post.preferredPlatform %}
              <span class="featured-pill">{{ post.preferredPlatform }}</span>
              {% endif %}
              <span class="featured-date">{{ post.monthYear }}</span>
            </div>
          </div>
        </a>
        {% endfor %}
      </div>
      {% endif %}
    </section>
    {% endif %}

    {# Expanded grid for the most recent archive year. #}
    {# Lead year section uses the larger image-card layout when available. #}
    {% if reviewsPage.leadYearSection %}
    <section
      class="year-section"
      aria-labelledby="year-{{ reviewsPage.leadYearSection.year }}"
      data-year-section
      data-year="{{ reviewsPage.leadYearSection.year }}"
    >
      <div class="section-heading">
        <span class="section-heading-text" id="year-{{ reviewsPage.leadYearSection.year }}">
          {{ reviewsPage.leadYearSection.year }}
        </span>
        <div class="section-heading-line"></div>
      </div>

      <div class="article-grid article-grid-two-col">
        {# Render each review card in the lead year's two-column grid. #}
        {% for post in reviewsPage.leadYearSection.items %}
        <a
          href="{{ post.href }}"
          class="article-card article-card-grid"
          data-post-card
          {% if post.isMock %}data-mock="true"{% endif %}
          data-date="{{ post.dateIso }}"
          data-year="{{ post.year }}"
          data-title="{{ post.titleLower }}"
          data-genres="{{ post.genresTokens }}"
          data-platforms="{{ post.platformsTokens }}"
        >
          <div class="article-thumb">{{ post.imageHtml | safe }}</div>
          <div class="article-info">
            <div class="article-genre">{{ post.genreLabel }}</div>
            <h3 class="article-title">{{ post.data.title }}</h3>
            <p class="article-excerpt">{{ post.excerpt }}</p>
            <div class="article-foot">
              <span class="article-date">
                <time datetime="{{ post.dateIso }}">{{ post.formattedDate }}</time>
              </span>
            </div>
          </div>
        </a>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    {# Compact list layout for older years. #}
    {# Older years render in compact grouped lists. #}
    {% for section in reviewsPage.compactSections %}
    <section
      class="year-section"
      aria-labelledby="year-{{ section.year }}"
      data-year-section
      data-year="{{ section.year }}"
    >
      <div class="year-divider">
        <span class="year-num" id="year-{{ section.year }}">{{ section.year }}</span>
        <div class="year-line"></div>
      </div>

      <div class="compact-list">
        {# Loop through compact rows for this year group. #}
        {% for post in section.items %}
        <a
          href="{{ post.href }}"
          class="compact-item"
          data-post-card
          {% if post.isMock %}data-mock="true"{% endif %}
          data-date="{{ post.dateIso }}"
          data-year="{{ post.year }}"
          data-title="{{ post.titleLower }}"
          data-genres="{{ post.genresTokens }}"
          data-platforms="{{ post.platformsTokens }}"
        >
          <span class="compact-num">{{ post.compactNum }}</span>
          <div class="compact-main">
            <div class="compact-title">{{ post.data.title }}</div>
            <div class="compact-sub">{{ post.genreLabel }} / {{ post.monthYear }}</div>
          </div>
          <span class="compact-badge badge-{{ post.badge.variant }}">{{ post.badge.label }}</span>
        </a>
        {% endfor %}
      </div>
    </section>
    {% endfor %}

    {# Empty state if there are no archive entries to render. #}
    {# Fallback message when no archive content is available. #}
    {% if reviewsPage.emptyArchive %}
    <section class="empty-state">
      <p>No additional review entries yet.</p>
    </section>
    {% endif %}
  </div>

  {# Sidebar summary modules (now playing + aggregate stats). #}
  <aside class="reviews-sidebar">
    <section class="sidebar-block">
      <div class="sidebar-header">
        <span class="sidebar-header-pip"></span>
        <span class="sidebar-header-text">Currently Playing</span>
      </div>
      <div class="now-list">
        {# Sidebar "currently playing" feed mirrors the global data list. #}
        {% for game in reviewsPage.sidebar.currentlyPlaying %}
        <div class="now-item">
          <span class="now-pulse" aria-hidden="true"></span>
          <div>
            <div class="now-title">{{ game.title }}</div>
            <div class="now-sub">
              {{ game.platform }}{% if game.status %} / {{ game.status }}{% endif %}
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
    </section>

    {# Only show stats modules when there is data to summarize. #}
    {% if reviewsPage.sidebar.topGenres.length > 0 %}
    <section class="sidebar-block">
      <div class="sidebar-header">
        <span class="sidebar-header-pip sidebar-header-pip-soft"></span>
        <span class="sidebar-header-text">By Genre</span>
      </div>
      <div class="genre-stack">
        {# Top genres include a count and a proportional bar width. #}
        {% for genre in reviewsPage.sidebar.topGenres %}
        <div class="genre-row">
          <div class="genre-item">
            <span class="genre-name">{{ genre.name }}</span>
            <span class="genre-count">{{ genre.count }}</span>
          </div>
          <div class="genre-bar-wrap" aria-hidden="true">
            <div class="genre-bar" style="width: {{ genre.widthPct }}%"></div>
          </div>
        </div>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    {# Platform summary grid is also optional. #}
    {% if reviewsPage.sidebar.topPlatforms.length > 0 %}
    <section class="sidebar-block">
      <div class="sidebar-header">
        <span class="sidebar-header-pip sidebar-header-pip-soft"></span>
        <span class="sidebar-header-text">By Platform</span>
      </div>
      <div class="platform-grid">
        {# Render platform counts as compact tiles. #}
        {% for platform in reviewsPage.sidebar.topPlatforms %}
        <div class="platform-item">
          <span class="platform-name">{{ platform.name }}</span>
          <span class="platform-count">{{ platform.count }}</span>
        </div>
        {% endfor %}
      </div>
    </section>
    {% endif %}
  </aside>
</div>

{# Inline script generated in index.11tydata.js to keep filter logic page-scoped. #}
<script>{{ reviewsPage.filterScript | safe }}</script>
