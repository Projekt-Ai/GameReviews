---
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import CommentsWidget from "../components/comments/CommentsWidget";
import LikeButton from "../components/LikeButton";
import "../styles/layouts/review-post.css";
import "../styles/layouts/review-post-variants.css";
import "../styles/components/comments.css";
import { formatDate } from "../lib/content";
import { getImageAsset } from "../lib/image-assets";

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  imageCredit,
  theme = "default",
  feature = false,
  comments = false,
  threadId,
  platforms = [],
  genres = [],
  release,
  price,
  currentSlug,
  allReviews = [],
  readingTime,
} = Astro.props;

const heroSrc = getImageAsset(heroImage);
const needsVariantFonts = theme === "e33";

const canonicalUrl = new URL(`/reviews/${currentSlug}/`, "https://katkronicles.com").href;
const heroImageUrl = heroSrc ? new URL(typeof heroSrc === "string" ? heroSrc : heroSrc.src, "https://katkronicles.com").href : undefined;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Review",
  "name": title,
  "author": { "@type": "Person", "name": "Kat" },
  "publisher": { "@type": "Organization", "name": "Kat's Kronicles", "url": "https://katkronicles.com" },
  "datePublished": pubDate.toISOString(),
  ...(updatedDate ? { "dateModified": updatedDate.toISOString() } : {}),
  "description": description,
  "url": canonicalUrl,
  ...(heroImageUrl ? { "image": heroImageUrl } : {}),
  "itemReviewed": {
    "@type": "VideoGame",
    "name": title,
    ...(genres.length > 0 ? { "genre": genres } : {}),
    ...(platforms.length > 0 ? { "gamePlatform": platforms.map(p => p.name) } : {}),
    ...(release ? { "datePublished": release } : {}),
  },
};

const { related: relatedGenres = [] } = Astro.props;
const currentGenres = new Set(genres.map((g) => g.toLowerCase()));
const targetGenres = new Set([...currentGenres, ...relatedGenres.map((g) => g.toLowerCase())]);
const related = allReviews
  .filter((r) => {
    if (r.slug === currentSlug) return false;
    const rGenres = (r.data.genres || []).map((g) => g.toLowerCase());
    return rGenres.some((g) => [...targetGenres].some((t) => g.includes(t) || t.includes(g)));
  })
  .slice(0, 5);

---

<BaseLayout
  title={title}
  description={description}
  image={heroSrc || undefined}
  bodyClass="review-post"
  dataTheme={theme}
  dataFeatured={feature ? "true" : "false"}
  variantFonts={needsVariantFonts}
  jsonLd={jsonLd}
>
  <article>
    <div class="hero-image">
      {heroSrc && <Image src={heroSrc} alt="" loading="eager" />}
      <div class="hero-title-wrap">
        <div class="hero-eyebrow">
          <span>Review</span>
          <span class="hero-eyebrow-dot" aria-hidden="true">&bull;</span>
          <span><time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time></span>
          {readingTime && (
            <>
              <span class="hero-eyebrow-dot" aria-hidden="true">&bull;</span>
              <span>{readingTime} min read</span>
            </>
          )}
        </div>
        <h1 class="hero-title">{title}</h1>
      </div>
    </div>
    <div class="review-content-wrap">
      <aside class="related-sidebar" aria-label="Related reviews">
        <div class="related-sidebar-inner">
          {related.length > 0 && (
            <>
              <h2 class="sidebar-heading">Related</h2>
              {related.map((r) => {
                const thumb = getImageAsset(r.data.heroImage);
                return (
                  <a href={`/reviews/${r.slug}/`} class="related-card">
                    <div class="related-img-wrap">
                      {thumb && <Image src={thumb} alt="" loading="lazy" />}
                    </div>
                    <div class="related-info">
                      <span class="related-genre">{(r.data.genres || []).slice(0, 2).join(" / ")}</span>
                      <h3 class="related-title">{r.data.title}</h3>
                    </div>
                  </a>
                );
              })}
            </>
          )}
        </div>
      </aside>
      <div class="prose">
        {updatedDate && (
          <div class="title title-meta-only">
            <div class="date">
              <div class="last-updated-on">
                Last updated on <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
              </div>
            </div>
          </div>
        )}
        <slot />
      </div>
      <aside class="review-sidebar" aria-label="Review details">
        <div class="sidebar-inner">
          {(genres.length > 0 || platforms.length > 0 || release || price) && (
            <>
              <h2 class="sidebar-heading">Details</h2>
              {genres.length > 0 && (
                <div class="sidebar-block">
                  <span class="sidebar-label">Genres</span>
                  <div class="sidebar-tags">
                    {genres.map((g) => <span class="sidebar-tag">{g}</span>)}
                  </div>
                </div>
              )}
              {platforms.length > 0 && (
                <div class="sidebar-block">
                  <span class="sidebar-label">Platforms</span>
                  <ul class="sidebar-list">
                    {platforms.map((p) => (
                      <li>
                        {p.name}
                        {p.played && <span class="sidebar-played" title="Played on this platform">&#x2713;</span>}
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              {release && (
                <div class="sidebar-block">
                  <span class="sidebar-label">Released</span>
                  <span class="sidebar-value">{release}</span>
                </div>
              )}
              {price && (
                <div class="sidebar-block">
                  <span class="sidebar-label">Price</span>
                  <span class="sidebar-value">{price}</span>
                </div>
              )}
            </>
          )}
        </div>
      </aside>
    </div>
  </article>

  <div class="like-bar">
    <LikeButton client:load slug={currentSlug} />
  </div>

  {comments && threadId && <CommentsWidget client:load thread={threadId} />}
</BaseLayout>
