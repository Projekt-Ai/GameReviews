---
// Layout for boss fight essay pages. Differs from ReviewLayout: no related-reviews sidebar,
// no reading time — instead has a boss info card, verdict section, and tone-styled tags.
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import CommentsWidget from "../components/comments/CommentsWidget";
import "../styles/layouts/boss-feature.css";
import "../styles/components/comments.css";
import { formatDate } from "../lib/content";
import { getImageAsset } from "../lib/image-assets";

const {
  title,
  description,
  pubDate,
  heroImage,
  imageCredit,
  game,
  bossType,
  attempts,
  verdict,
  verdictTone,
  verdictText,
  spoilerLevel,
  hoursIn,
  chapter,
  blurb,
  tags = [],
  comments = false,
  threadId,
  currentSlug,
} = Astro.props;

const heroSrc = getImageAsset(heroImage);
const pageTitle = `${title} | Boss Feature`;
const verdictToneClass = verdictTone ? `bf-verdict-${verdictTone}` : "";

const canonicalUrl = currentSlug ? new URL(`/bossfeatures/${currentSlug}/`, "https://katkronicles.com").href : undefined;
const heroImageUrl = heroSrc ? new URL(typeof heroSrc === "string" ? heroSrc : heroSrc.src, "https://katkronicles.com").href : undefined;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "author": { "@type": "Person", "name": "Kat" },
  "publisher": { "@type": "Organization", "name": "Kat's Kronicles", "url": "https://katkronicles.com" },
  "datePublished": pubDate.toISOString(),
  "description": description,
  ...(canonicalUrl ? { "url": canonicalUrl } : {}),
  ...(heroImageUrl ? { "image": heroImageUrl } : {}),
  "about": {
    "@type": "VideoGame",
    "name": game,
  },
};

// manually maintained — each key maps to a CSS colour class defined in boss-feature.css
const tagClasses = {
  memorable: "bf-tag-memorable",
  fair: "bf-tag-fair",
  spectacle: "bf-tag-spectacle",
  punishing: "bf-tag-punishing",
  narrative: "bf-tag-narrative",
  unfair: "bf-tag-unfair",
  forgettable: "bf-tag-forgettable",
};
---

<BaseLayout title={pageTitle} description={description} image={heroSrc || undefined} bodyClass="boss-feature" variantFonts jsonLd={jsonLd}>
  <section class="bf-hero">
    {heroSrc && (
      <div class="bf-hero-img">
        <Image src={heroSrc} alt="" loading="eager" />
      </div>
    )}
    <div class="bf-hero-bg"></div>
    <div class="bf-hero-lines" aria-hidden="true"></div>
    <div class="bf-hero-vignette" aria-hidden="true"></div>

    <div class="bf-hero-content">
      <div class="bf-boss-tag">Boss Feature</div>
      <p class="bf-hero-game">{game}</p>
      <h1 class="bf-hero-title">{title}</h1>
      {blurb && <p class="bf-hero-subtitle">{blurb}</p>}
      <div class="bf-hero-meta">
        <span class="bf-hero-meta-item">By KAT</span>
        {hoursIn && (
          <>
            <span class="bf-hero-meta-sep" aria-hidden="true"></span>
            <span class="bf-hero-meta-item">{hoursIn}</span>
          </>
        )}
        {chapter && (
          <>
            <span class="bf-hero-meta-sep" aria-hidden="true"></span>
            <span class="bf-hero-meta-item">{chapter}</span>
          </>
        )}
        <span class="bf-hero-meta-sep" aria-hidden="true"></span>
        <span class="bf-hero-meta-item">
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        </span>
      </div>
    </div>
  </section>

  <div class="bf-article-wrap">
    <div class="bf-byline">
      <span><strong>KAT</strong></span>
      <span class="bf-byline-sep">&middot;</span>
      <span>{game}</span>
      <span class="bf-byline-sep">&middot;</span>
      <span>Boss Feature</span>
    </div>

    <div class="bf-boss-card">
      <div class="bf-boss-card-field">
        <span class="bf-boss-card-label">Boss</span>
        <span class="bf-boss-card-value">{title}</span>
      </div>
      <div class="bf-boss-card-field">
        <span class="bf-boss-card-label">Game</span>
        <span class="bf-boss-card-value">{game}</span>
      </div>
      <div class="bf-boss-card-field">
        <span class="bf-boss-card-label">Type</span>
        <span class="bf-boss-card-value">{bossType}</span>
      </div>
      {attempts !== undefined && (
        <div class="bf-boss-card-field">
          <span class="bf-boss-card-label">Attempts</span>
          <span class="bf-boss-card-value">{attempts}</span>
        </div>
      )}
      {verdict && (
        <div class="bf-boss-card-field">
          <span class="bf-boss-card-label">Verdict</span>
          <span class={`bf-boss-card-value ${verdictToneClass}`}>{verdict}</span>
        </div>
      )}
      {spoilerLevel && (
        <div class="bf-boss-card-field">
          <span class="bf-boss-card-label">Spoiler Level</span>
          <span class="bf-boss-card-value">{spoilerLevel}</span>
        </div>
      )}
    </div>

    <slot />

    {verdictText && (
      <div class="bf-verdict">
        <p class="bf-verdict-eyebrow">Final Take</p>
        <p class="bf-verdict-text">{verdictText}</p>
        {tags.length > 0 && (
          <div class="bf-verdict-tags">
            {tags.map((tag) => (
              <span class={`bf-verdict-tag ${tagClasses[tag.toLowerCase()] || "bf-tag-spectacle"}`}>{tag}</span>
            ))}
          </div>
        )}
      </div>
    )}
  </div>

  {comments && threadId && <CommentsWidget client:load thread={threadId} />}
</BaseLayout>
