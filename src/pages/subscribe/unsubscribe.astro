---
import BaseLayout from "../../layouts/BaseLayout.astro";
const API_URL = import.meta.env.PUBLIC_COMMENTS_API || 'http://localhost:3000';
---

<BaseLayout title="Unsubscribe" description="Unsubscribe from Kat's Kronicles.">
  <div class="confirm-page">
    <div class="confirm-card" id="confirm-card">
      <div class="confirm-spinner" id="confirm-spinner">
        <span class="confirm-pip"></span>
        <p class="confirm-status">Unsubscribing…</p>
      </div>
      <div class="confirm-success" id="confirm-success" hidden>
        <p class="confirm-eyebrow">Done</p>
        <h1 class="confirm-heading">You've been unsubscribed.</h1>
        <p class="confirm-body">You won't receive any more emails from Kat's Kronicles.</p>
        <a class="confirm-btn" href="/">Back to the site</a>
      </div>
      <div class="confirm-error" id="confirm-error" hidden>
        <p class="confirm-eyebrow">Something went wrong</p>
        <h1 class="confirm-heading">Link not valid.</h1>
        <p class="confirm-body">This unsubscribe link may have already been used or is invalid.</p>
        <a class="confirm-btn" href="/">Back to the site</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .confirm-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    padding: 2rem 1.25rem;
  }

  .confirm-card {
    width: min(480px, 100%);
    padding: 2.5rem 2rem;
    border: 1px solid rgba(190, 173, 229, 0.14);
    border-radius: 2px;
    background: linear-gradient(165deg, rgba(24, 18, 50, 0.85), rgba(34, 14, 48, 0.8));
    text-align: center;
  }

  .confirm-eyebrow {
    margin: 0 0 0.4rem;
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #ff4fa3;
  }

  .confirm-heading {
    margin: 0 0 0.75rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: #e3dbf1;
  }

  .confirm-body {
    margin: 0 0 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: rgba(226, 217, 243, 0.6);
    line-height: 1.6;
  }

  .confirm-btn {
    display: inline-block;
    padding: 0.6rem 1.4rem;
    background: #ff4fa3;
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: opacity 0.15s ease;
  }

  .confirm-btn:hover { opacity: 0.85; }

  .confirm-spinner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .confirm-pip {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: #ff4fa3;
    animation: pulse 1.2s ease-in-out infinite;
  }

  .confirm-status {
    margin: 0;
    font-family: var(--font-display);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(226, 217, 243, 0.45);
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.3; transform: scale(0.7); }
  }
</style>

<script define:vars={{ API_URL }}>
  const token = new URLSearchParams(window.location.search).get('token');
  const spinner = document.getElementById('confirm-spinner');
  const success = document.getElementById('confirm-success');
  const error = document.getElementById('confirm-error');

  async function unsubscribe() {
    if (!token) {
      spinner.hidden = true;
      error.hidden = false;
      return;
    }
    try {
      const res = await fetch(`${API_URL}/subscribe/unsubscribe?token=${token}`);
      spinner.hidden = true;
      if (res.ok) {
        success.hidden = false;
      } else {
        error.hidden = false;
      }
    } catch {
      spinner.hidden = true;
      error.hidden = false;
    }
  }

  unsubscribe();
</script>
