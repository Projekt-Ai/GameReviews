---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/pages/home.css";
import { formatDate, formatGenreLine, getGotyReviews, getVisibleReviews } from "../lib/content";
import { fallbackCardImage, getImageAsset } from "../lib/image-assets";

const [reviews, gotyCandidates] = await Promise.all([getVisibleReviews(), getGotyReviews()]);
const gotyAscending = [...gotyCandidates].sort((a, b) => (a.data.gotyYear ?? 0) - (b.data.gotyYear ?? 0));
const gotyDescending = [...gotyCandidates].sort((a, b) => (b.data.gotyYear ?? 0) - (a.data.gotyYear ?? 0));
// most recent year's pick is always the "Pinned" card; everything else goes into the carousel
const pinned = gotyDescending[0];
const slideshowPool = gotyAscending.filter((entry) => entry.slug !== pinned?.slug);
// fallback to gotyAscending when there's only one year (pool would otherwise be empty)
const slideshow = slideshowPool.length > 0 ? slideshowPool.slice(0, 3) : gotyAscending.slice(0, 3);
const recent = reviews.slice(0, 4);
const highlightReview = reviews.find(r => r.data.highlight) ?? null;

// returns "Archive" as a safety net so the GOTY card never renders with an empty platform list
function playedPlatforms(platforms = []) {
  return platforms.length > 0 ? platforms : [{ name: "Archive", played: false }];
}

---

<BaseLayout mainClass="home-main" variantFonts>
  {slideshow.length > 0 && (
    
    <section class="goty-spotlight">
      <p class="goty-eyebrow">Game of the Year &middot; My Picks</p>

      <div class="goty-layout">
        <div class="goty-carousel-wrap">
          <div class="goty-slider-wrap" data-goty-slider-wrap data-default-index="0">
            <div class="goty-slider" data-goty-slider aria-label="Game of the Year slideshow">
              {slideshow.map((post) => (
                <div class="goty-slide">
                  <article class={`featured article goty year-${post.data.gotyYear}`}>
                    <div class="article-background">
                      <Image loading="eager" src={getImageAsset(post.data.heroImage, fallbackCardImage)} alt={post.data.title} />
                    </div>
                    <div class="article-overlay"></div>
                    <div class={`ribbon year-${post.data.gotyYear}`}>
                      <span class="ribbon-text">{post.data.gotyYear}</span>
                    </div>
                    <div class="article-content">
                      <p class="article-label">My Game of the Year {post.data.gotyYear}</p>
                      <h2 class="article-title">{post.data.title}</h2>
                      <p class="article-meta">
                        {playedPlatforms(post.data.platforms).map((platform, index) => (
                          <>
                            <span class={platform.played ? "my-platform" : undefined}>{platform.name}</span>
                            {index < playedPlatforms(post.data.platforms).length - 1 && <span class="platform-separator"> / </span>}
                          </>
                        ))}
                      </p>
                      <p class="article-meta">{formatGenreLine(post.data.genres, post.data.release)}</p>
                      <p class="article-blurb">{post.data.blurb || post.data.description}</p>
                      <a href={`/reviews/${post.slug}/`} class="read-more">Read More</a>
                    </div>
                    <p class="image-credit">{post.data.imageCredit || ""}</p>
                  </article>
                </div>
              ))}
            </div>
          </div>

          <div class="goty-controls">
            <div class="goty-dots">
              {slideshow.map((post, index) => (
                <button
                  type="button"
                  class={`goty-dot${index === 0 ? " is-active" : ""}`}
                  data-goty-dot
                  data-goty-index={index}
                  aria-label={`Go to ${post.data.title}`}
                ></button>
              ))}
            </div>
            <div class="goty-arrow-group">
              <button type="button" class="goty-arrow" data-goty-prev aria-label="Previous slide">&lsaquo;</button>
              <button type="button" class="goty-arrow" data-goty-next aria-label="Next slide">&rsaquo;</button>
            </div>
          </div>
        </div>

        {pinned && (
          <div class="goty-pin" aria-label="Pinned Game of the Year">
            <article class={`featured article goty year-${pinned.data.gotyYear}`}>
              <div class="article-background">
                <Image loading="eager" src={getImageAsset(pinned.data.heroImage, fallbackCardImage)} alt={pinned.data.title} />
              </div>
              <div class="article-overlay"></div>
              <div class={`ribbon year-${pinned.data.gotyYear}`}>
                <span class="ribbon-text">{pinned.data.gotyYear}</span>
              </div>
              <div class="article-content">
                <p class="article-label">Pinned Pick</p>
                <h2 class="article-title">{pinned.data.title}</h2>
                <p class="article-meta">{formatGenreLine(pinned.data.genres, pinned.data.release)}</p>
                <p class="article-blurb">{pinned.data.blurb || pinned.data.description}</p>
                <a href={`/reviews/${pinned.slug}/`} class="read-more">Read More</a>
              </div>
              <p class="image-credit">{pinned.data.imageCredit || ""}</p>
            </article>
          </div>
        )}
      </div>
    </section>
  )}

  <div class="content-and-sidebar">
    <div class="content-column">
      <section class="site-intro">
        <p class="intro-eyebrow">Summary</p>
        <blockquote class="site-intro-lede">
          I was tired of only talking with people about the games I hate, and I wanted a place to write about the ones I love. This is that place.
        </blockquote>
        <div class="site-intro-text">
          <p>
            I'm not a professional critic. I would hesitate to say I'm trying to be. I'm trying to write pieces
            that are worth reading six months after a game comes out, because most of what I have to say
            doesn't arrive until I've had time to sit with it.
          </p>
          <p>
            Most of what I play is some form of RPG, action or otherwise. I enjoy when the medium is used to
            express something — a concept, a feeling, even just a person finding their family.
            I have a high tolerance for slow starts and a low tolerance for bad final acts.
          </p>
          <p>
            Everything on this site is written from direct experience. A <strong>review</strong> is long-form and first-person — my raw take, no scores.
            A <strong>boss feature</strong> is a close reading of one fight: mechanics, mood, and what the encounter says about the game around it.
          </p>
        </div>
      </section>

      <div class="feature-recents-stack">
        {highlightReview && (
          <section class="year-highlight">
            <p class="section-eyebrow">Year's Highlight</p>
            <a href={`/reviews/${highlightReview.slug}/`} class="highlight-panel">
              <div class="highlight-image-shell">
                <div class="highlight-image">
                  <Image loading="eager" src={getImageAsset(highlightReview.data.heroImage, fallbackCardImage)} alt={highlightReview.data.title} />
                </div>
              </div>
              <div class="highlight-content">
                <span class="highlight-tag">{highlightReview.data.genres?.[0]}</span>
                <h2 class="highlight-title">{highlightReview.data.headline ?? highlightReview.data.title}</h2>
                <p class="highlight-game">{highlightReview.data.title}</p>
                <p class="highlight-blurb">{highlightReview.data.blurb ?? highlightReview.data.description}</p>
                <span class="highlight-cta">Read Review &rarr;</span>
              </div>
            </a>
          </section>
        )}

        <section class="recent-articles">
          <div class="section-header">
            <h2 class="section-title">Recent</h2>
            <a href="/reviews/" class="section-link">View All &rarr;</a>
          </div>

          <div class="recents-list">
            {recent.map((post, index) => (
              <a href={`/reviews/${post.slug}/`} class={`recent-item recent-item-${index + 1}`}>
                <div class="recent-thumb">
                  <Image src={getImageAsset(post.data.heroImage, fallbackCardImage)} alt={post.data.title} />
                </div>
                <div class="recent-content">
                  <div class="recent-time">
                    <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                  </div>
                  <h3 class="recent-title">{post.data.title}</h3>
                  <p class="recent-excerpt">{post.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        </section>

      </div>
    </div>

  </div>

  <script is:inline src="/js/home-goty-slider.js"></script>
</BaseLayout>
