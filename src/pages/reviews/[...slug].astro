---
import { getVisibleReviews } from "../../lib/content";
import ReviewLayout from "../../layouts/ReviewLayout.astro";

export async function getStaticPaths() {
  const reviews = await getVisibleReviews();
  return reviews.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, allReviews: reviews },
  }));
}

const { entry, allReviews } = Astro.props;
const { Content } = await entry.render();
---

<ReviewLayout
  title={entry.data.title}
  description={entry.data.description}
  pubDate={entry.data.pubDate}
  updatedDate={entry.data.updatedDate}
  heroImage={entry.data.heroImage}
  imageCredit={entry.data.imageCredit}
  theme={entry.data.theme}
  feature={entry.data.feature}
  comments={entry.data.comments}
  threadId={entry.slug}
  platforms={entry.data.platforms}
  genres={entry.data.genres}
  release={entry.data.release}
  related={entry.data.related}
  currentSlug={entry.slug}
  allReviews={allReviews}
>
  <Content />
</ReviewLayout>
